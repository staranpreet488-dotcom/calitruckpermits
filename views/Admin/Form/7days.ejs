  </div>
  <script>
    function getLast7Days() {
  const days = [];

  for (let i = 0; i < 7; i++) {
    const d = new Date();
    d.setDate(d.getDate() - i);

    days.push({
      date: d,
      label: d.toLocaleDateString("en-US", {
        weekday: "short",
        month: "short",
        day: "numeric"
      })
    });
  }

  return days;
}

function renderDays() {
  const container = document.getElementById("daysContainer");
  const days = getLast7Days();

  container.innerHTML = days.map((day, i) => `
    <div class="grid grid-cols-2 px-6 py-3 items-center">

      <span class="text-sm font-medium text-gray-700">
        Day ${i + 1} (${day.label})
      </span>

      <input
        type="number"
        min="0"
        max="24"
        step="0.5"
        name="days[${i}][hours]"
        data-date="${day.date.toISOString()}"
        class="hoursInput border rounded-lg px-3 py-2 max-w-[160px]"
        placeholder="0.0"
      />

    </div>
  `).join("");

  attachListeners();
}

function attachListeners() {
  const inputs = document.querySelectorAll(".hoursInput");

  inputs.forEach(input => {
    input.addEventListener("input", calculateTotal);
  });
}

function calculateTotal() {
  const inputs = document.querySelectorAll(".hoursInput");
  let total = 0;

  inputs.forEach(i => {
    total += Number(i.value || 0);
  });

  document.getElementById("totalHours").value = total;
}

// init
renderDays();
  </script>