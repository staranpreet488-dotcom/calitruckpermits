<div class="form-step" data-step="0">
    <div class="mx-auto mt-3 bg-white shadow-lg rounded-xl p-6">
      <!-- HEADER -->
      <h2 class="text-lg font-semibold text-blue-600 border-b pb-2">
        Personal Information
      </h2>

      <!-- GRID -->
      <div class="grid md:grid-cols-3 gap-4 mt-4">
        <div>
          <label class="text-sm text-gray-600">First Name <span class="text-red-600">*</span></label>
          <input
            type="text"
            placeholder="First Name"
            name="FirstName"
            class="w-full mt-1 p-2 border rounded focus:ring-2 focus:ring-blue-400"
          />
        </div>

        <div>
          <label class="text-sm text-gray-600">Last Name <span class="text-red-600">*</span></label>
          <input   name="LastName"
            type="text"
            placeholder="Last Name"
            class="w-full mt-1 p-2 border rounded focus:ring-2 focus:ring-blue-400"
          />
        </div>

        <div>
          <label class="text-sm text-gray-600">SSN <span class="text-red-600">*</span></label>
          <input   name="SSN"
            type="text"
            placeholder="xxx-xx-xxxx"
            class="w-full mt-1 p-2 border rounded focus:ring-2 focus:ring-blue-400"
          />
        </div>

        <div>
          <label class="text-sm text-gray-600">Contact Number <span class="text-red-600">*</span></label>
          <input   name="Contact"
            type="text"
            placeholder="10-15 digit number"
            class="w-full mt-1 p-2 border rounded"
          />
        </div>

        <div>
          <label class="text-sm text-gray-600">Alt Contact</label>
          <input   name="AltContact"
            type="text"
            placeholder="Optional"
            class="w-full mt-1 p-2 border rounded"
          />
        </div>

        <div>
          <label class="text-sm text-gray-600">Date of Birth <span class="text-red-600">*</span></label>
          <input   name="Dob" type="date" class="w-full mt-1 p-2 border rounded" />
        </div>

        <div class="md:col-span-2">
          <label class="text-sm text-gray-600">Email <span class="text-red-600">*</span></label>
          <input   name="Email"
            type="email"
            placeholder="email@example.com"
            class="w-full mt-1 p-2 border rounded"
          />
        </div>

        <div class="md:col-span-3">
          <label class="text-sm text-gray-600">Address <span class="text-red-600">*</span></label>
          <input   name="Address"
            type="text"
            placeholder="123 Main St"
            class="w-full mt-1 p-2 border rounded"
          />
        </div>

        <div>
          <label class="text-sm text-gray-600">City <span class="text-red-600">*</span></label>
          <input   name="City" class="w-full mt-1 p-2 border rounded" />
        </div>

        <div>
          <label class="text-sm text-gray-600">State <span class="text-red-600">*</span></label>
          <input   name="State" class="w-full mt-1 p-2 border rounded" />
        </div>

        <div>
          <label class="text-sm text-gray-600">Zip Code <span class="text-red-600">*</span></label>
          <input   name="Zip" class="w-full mt-1 p-2 border rounded" />
        </div>
      </div>

      <!-- MEDICAL SECTION -->
      <h2 class="text-lg font-semibold mt-8 border-b pb-2">
        Medical & Identification
      </h2>

      <div class="grid md:grid-cols-3 gap-4 mt-4">
        <div>
          <label class="text-sm text-gray-600">Medical Registry <span class="text-red-600">*</span></label>
          <input   name="MedicalRegistry" class="w-full mt-1 p-2 border rounded" />
        </div>

        <div>
          <label class="text-sm text-gray-600">Medical Expiry <span class="text-red-600">*</span></label>
          <input   name="MedicalExpiry" type="date" class="w-full mt-1 p-2 border rounded" />
        </div>

        <div>
          <label class="text-sm text-gray-600">TWIC Card?</label>
          <div class="flex gap-4 mt-2">
            <label><input type="radio" name="TWIC"  value="Yes" /> Yes</label>
            <label><input type="radio" name="TWIC"  value="No" /> No</label>
          </div>
        </div>

        <div>
          <label class="text-sm text-gray-600">Passport?</label>
          <div class="flex gap-4 mt-2">
            <label><input type="radio" name="Passport"  value="Yes"/> Yes</label>
            <label><input type="radio" name="Passport"  value="No" /> No</label>
          </div>
        </div>
      </div>

      <!-- UPLOAD BOX -->
      <div class="mt-6">
        <label class="text-sm text-gray-600">Upload Medical Card <span class="text-red-600">*</span></label>
      
        <label
          class="mt-2 border-2 border-dashed rounded-lg p-6 text-center cursor-pointer hover:bg-gray-50 block"
        >
          <p class="text-gray-500 text-sm">Upload a file or drag and drop</p>
          <p class="text-xs text-gray-400">PNG, JPG, PDF up to 10MB</p>
      
          <!-- Hidden File Input -->
          <input
            type="file"
            class="hidden"
            name="image1"
            accept=".png,.jpg,.jpeg,.pdf"
            onchange="handleFileUpload(event)"
          />
        </label>
      </div>

      <!-- SOCIAL CARD -->
      <h2 class="text-lg font-semibold mt-8 border-b pb-2">
        Social Security Card
      </h2>

      <div class="mt-4">
        
        <label class="text-sm text-gray-600"
          >Upload Social Security Card <span class="text-red-600">*</span></label
        >
 
    
        <label
        class="mt-2 border-2 border-dashed rounded-lg p-6 text-center cursor-pointer hover:bg-gray-50 block"
      >
        <p class="text-gray-500 text-sm">Upload Social Security Card <span class="text-red-600">*</span></p>
        <p class="text-xs text-gray-400">PNG, JPG, PDF up to 10MB</p>
    
        <!-- Hidden File Input -->
        <input
          type="file"
          name="image1"

          class="hidden"
          accept=".png,.jpg,.jpeg,.pdf"
          onchange="handleFileUpload(event)"
        />
      </label>
      </div>

      <!-- BUTTON -->
      <div class="flex justify-between items-center mt-8">
      

        <button class="next-btn bg-blue-600 text-white px-6 py-2 rounded-lg">
          Next Step →
        </button>
      </div>
    </div>
  </div>

  <script>
    function handleFileUpload(event) {
      const file = event.target.files[0];
      if (file) {
        console.log("Selected file:", file.name);
        alert("File selected: " + file.name);
      }
    }
  </script>
  