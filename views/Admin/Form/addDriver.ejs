    <script>
      const loader = document.getElementById("loader");
      document.querySelector(".submit-application-btn").addEventListener("click", async () => {
        loader.style.display = "flex"; // 🔥 SHOW LOADER
        // 🔥 STEP DATA SAVE (VERY IMPORTANT)
        saveStep0();
        saveStep1();
        saveStep2();
        saveStep3();
        saveStep4();
        saveStep5();
        saveStep6();
      
        console.log("FINAL DATA:", formData);
      
        const form = document.querySelector("form");
        const fd = new FormData(form); // files + inputs
      
        // 🔥 FULL JSON DATA ADD
        fd.append("data", JSON.stringify(formData));
      
        // 🔥 SIGNATURE FIX
        const canvas = document.querySelector('[data-key="ApplicantSignature"]');
        if (canvas) {
          const signature = canvas.toDataURL("image/png");
          console.log("SIGNATURE LENGTH:", signature.length);
          fd.append("Sign", signature);
        }
      
        // 🔥 CONSENTS FIX
        const consents = {};
        document.querySelectorAll(".consent-checkbox").forEach((cb) => {
          consents[cb.dataset.key] = cb.checked;
        });
      
        fd.append("consents", JSON.stringify(consents));
      
        // 🔥 DEBUG (CHECK KI JA REHA)
        for (let pair of fd.entries()) {
          console.log(pair[0], pair[1]);
        }
      
        try {
          const res = await fetch("/<%= company?.slug %>/add-driver", {
            method: "POST",
            body: fd
          });
      
          const data = await res.json();
        
          console.log("SERVER RESPONSE:", data);
      
          if (data.success) {
             document.getElementById("thankYouModal").style.display = "flex";
          } else {
            alert("Submission failed!");
          }
      
        } catch (err) {
          console.error(err);
          alert("Error submitting form");
        }
        finally {
          loader.style.display = "none"; 
        }
      });


      function closeModal() {
  
  localStorage.setItem("formStep", "0");



  document.getElementById("thankYouModal").style.display = "none";
    location.reload();
}
      </script>

