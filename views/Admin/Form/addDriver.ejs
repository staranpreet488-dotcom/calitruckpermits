<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Driver Application</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/feather-icons"></script>
    <!-- Heroicons -->
    <style>
      .error-border {
  border: 1px solid red !important;
}

.error-msg {
  font-size: 12px;
}
      .step {
        cursor: pointer;
      }

      .active {
        color: #2563eb;
        font-weight: 600;
        border-bottom: 2px solid #2563eb;
        padding-bottom: 4px;
      }
    </style>
    <style>
      .active-circle {
        background-color: #3b82f6;
        color: white;
      }

      .completed-circle {
        background-color: #22c55e;
        color: white;
      }

      .completed-line {
        background-color: #22c55e;
      }
    </style>
  </head>

  <body class="bg-gray-100 px-4 md:px-[200px] py-4 md:py-8">
  
    <!-- HEADER -->
    <form action="" method="POST" enctype="multipart/form-data">
  
    <div
      class="bg-white rounded-xl shadow p-4 md:p-5 flex flex-col md:flex-row justify-between gap-4"
    >
      <div class="flex items-start gap-4">
        <div
          class="w-12 h-12 bg-blue-100 flex items-center justify-center rounded-lg text-2xl"
        >
          <img
            class="min-w-28"
            src="/app-assets/images/MATTRIFELOGO.png"
            height="100"
          />
        </div>

        <div>
          <h2 class="text-lg md:text-xl font-bold">
            <%= company?.name ? company.name.charAt(0).toUpperCase() +
            company.name.slice(1) : 'undefined' %>
          </h2>
          <p class="text-sm text-gray-500">
            Applying for professional driver position
          </p>

          <div class="flex flex-wrap gap-2 mt-2">
            <span class="bg-blue-100 text-blue-600 text-xs px-2 py-1 rounded"
              >DOT# <%= company?.DOT ? company.DOT : 'undefined' %></span
            >
            <span class="bg-gray-200 text-gray-700 text-xs px-2 py-1 rounded"
              ><%= company?.MC ? company.MC : 'undefined' %></span
            >
          </div>
        </div>
      </div>

      <div class="text-sm text-gray-600 md:text-right">
        <p>
          📍 <%= company?.Street %>, <%= company?.City %> ,<%= company?.State %>
          <%= company?.ZipCode %>
        </p>
        <p>📞 <%= company?.PhoneNumber %></p>
        <p>✉ <%= company?.EmailAddress %></p>
      </div>
    </div>

    <!-- STEPPER (RESPONSIVE) -->
    <div class="mt-6 overflow-x-auto">
      <div
        class="min-w-[700px] md:min-w-full flex items-center justify-between"
      >
        <!-- STEP 1 -->
        <div class="flex items-center flex-1" data-step="0">
          <!-- ICON CIRCLE -->
          <div
            class="circle w-10 h-10 bg-blue-500 text-white rounded-full flex items-center justify-center"
          >
            <!-- Heroicon: truck -->
            <i class="text-gray" data-feather="truck"></i>
          </div>

          <!-- LINE -->
          <div class="h-1 flex-1 bg-gray-300"></div>
        </div>

        <!-- STEP 2 -->
        <div class="flex items-center flex-1" data-step="1">
          <div
            class="circle w-10 h-10 border rounded-full flex items-center justify-center"
          >
            <i class="text-gray" data-feather="home"></i>
          </div>
          <div class="h-1 flex-1 bg-gray-300"></div>
        </div>

        <!-- STEP 3 -->
        <div class="flex items-center flex-1" data-step="2">
          <div
            class="circle w-10 h-10 border rounded-full flex items-center justify-center"
          >
            <i data-feather="credit-card"></i>
          </div>
          <div class="h-1 flex-1 bg-gray-300"></div>
        </div>

        <!-- STEP 4 -->
        <div class="flex items-center flex-1" data-step="3">
          <div
            class="circle w-10 h-10 border rounded-full flex items-center justify-center"
          >
            ✓
          </div>
          <div class="h-1 flex-1 bg-gray-300"></div>
        </div>

        <!-- STEP 5 -->
        <div class="flex items-center flex-1" data-step="4">
          <div
            class="circle w-10 h-10 border rounded-full flex items-center justify-center"
          >
            <i data-feather="alert-triangle"></i>
          </div>
          <div class="h-1 flex-1 bg-gray-300"></div>
        </div>
        <div class="flex items-center flex-1" data-step="5">
          <div
            class="circle w-10 h-10 border rounded-full flex items-center justify-center"
          >
            <i data-feather="briefcase"></i>
          </div>
          <div class="h-1 flex-1 bg-gray-300"></div>
        </div>
        <div class="flex items-center flex-1" data-step="6">
          <div
            class="circle w-10 h-10 border rounded-full flex items-center justify-center"
          >
            <i data-feather="alert-triangle"></i>
          </div>
          <div class="h-1 flex-1 bg-gray-300"></div>
        </div>
        <div
          class="circle w-10 h-10 border rounded-full flex items-center justify-center"
        >
          <i data-feather="briefcase"></i>
        </div>
      </div>
      <!-- STEP 6 -->
      <div class="flex items-center"></div>
    </div>

    <!-- LABELS -->
    <div
      id="steps"
      class="hidden md:flex justify-between text-xs text-gray-500 mt-2 px-2"
    >
      <span class="step" data-step="0">Personal</span>
      <span class="step" data-step="1">Residence</span>
      <span class="step" data-step="2">License</span>
      <span class="step" data-step="3">Experience</span>
      <span class="step" data-step="4">Incidents</span>
      <span class="step" data-step="5">Employment</span>
      <span class="step" data-step="6">7 Days Duty</span>
      <span class="step" data-step="7">Consents</span>
    </div>

    <!-- PROGRESS -->

    <div class="form-step" data-step="0">
      <div class="mx-auto mt-3 bg-white shadow-lg rounded-xl p-6">
        <!-- HEADER -->
        <h2 class="text-lg font-semibold text-blue-600 border-b pb-2">
          Personal Information
        </h2>
  
        <!-- GRID -->
        <div class="grid md:grid-cols-3 gap-4 mt-4">
          <div>
            <label class="text-sm text-gray-600">First Name <span class="text-red-600">*</span></label>
            <input
              type="text"
              placeholder="First Name"
              name="FirstName"
              class="w-full mt-1 p-2 border rounded focus:ring-2 focus:ring-blue-400"
              required
            />
             <small class="text-red-500 hidden error-msg">First Name is required</small>
          </div>
  
          <div>
            <label class="text-sm text-gray-600">Last Name <span class="text-red-600">*</span></label>
            <input   name="LastName"
              type="text"
              placeholder="Last Name"
              class="w-full mt-1 p-2 border rounded focus:ring-2 focus:ring-blue-400"
              required
            />
           <small class="text-red-500 hidden error-msg">Last Name is required</small>
          </div>
  
          <div>
            <label class="text-sm text-gray-600">SSN <span class="text-red-600">*</span></label>
            <input   name="SSN"
              type="text"
              placeholder="xxx-xx-xxxx"
              class="w-full mt-1 p-2 border rounded focus:ring-2 focus:ring-blue-400"
              required
            />
           <small class="text-red-500 hidden error-msg">SSN  is required</small>
          </div>
  
          <div>
            <label class="text-sm text-gray-600">Contact Number <span class="text-red-600">*</span></label>
            <input   name="Contact"
              type="text"
              placeholder="10-15 digit number"
              class="w-full mt-1 p-2 border rounded"
              required
            />
           <small class="text-red-500 hidden error-msg">Contact Number is required</small>
          </div>
  
          <div>
            <label class="text-sm text-gray-600">Alt Contact</label>
            <input   name="AltContact"
              type="text"
              placeholder="Optional"
              class="w-full mt-1 p-2 border rounded"
            />
         
          </div>
  
          <div>
            <label class="text-sm text-gray-600">Date of Birth <span class="text-red-600">*</span></label>
            <input   name="Dob" type="date" class="w-full mt-1 p-2 border rounded" required />
           <small class="text-red-500 hidden error-msg">Date of Birth is required</small>
          </div>
  
          <div class="md:col-span-2">
            <label class="text-sm text-gray-600">Email <span class="text-red-600">*</span></label>
            <input   name="Email"
              type="email"
              placeholder="email@example.com"
              class="w-full mt-1 p-2 border rounded" required
            />
           <small class="text-red-500 hidden error-msg">Email is required</small>
          </div>
  
          <div class="md:col-span-3">
            <label class="text-sm text-gray-600">Address <span class="text-red-600">*</span></label>
            <input   name="Address"
              type="text"
              placeholder="123 Main St"
              class="w-full mt-1 p-2 border rounded" required
            />
           <small class="text-red-500 hidden error-msg">Address is required</small>
          </div>
  
          <div>
            <label class="text-sm text-gray-600">City <span class="text-red-600">*</span></label>
            <input   name="City" class="w-full mt-1 p-2 border rounded" required />
           <small class="text-red-500 hidden error-msg">City is required</small>
          </div>
  
          <div>
            <label class="text-sm text-gray-600">State <span class="text-red-600">*</span></label>
            <input   name="State" class="w-full mt-1 p-2 border rounded" required />
           <small class="text-red-500 hidden error-msg">State is required</small>
          </div>
  
          <div>
            <label class="text-sm text-gray-600">Zip Code <span class="text-red-600">*</span></label>
            <input   name="Zip" class="w-full mt-1 p-2 border rounded" required />
           <small class="text-red-500 hidden error-msg">Zip Code is required</small>
          </div>
        </div>
  
        <!-- MEDICAL SECTION -->
        <h2 class="text-lg font-semibold mt-8 border-b pb-2">
          Medical & Identification
        </h2>
  
        <div class="grid md:grid-cols-3 gap-4 mt-4">
          <div>
            <label class="text-sm text-gray-600">Medical Registry <span class="text-red-600">*</span></label>
            <input   name="MedicalRegistry" class="w-full mt-1 p-2 border rounded" required />
            <small class="text-red-500 hidden error-msg">Medical Registry is required</small>
          </div>
         
          <div>
            <label class="text-sm text-gray-600">Medical Expiry <span class="text-red-600">*</span></label>
            <input   name="MedicalExpiry" type="date" class="w-full mt-1 p-2 border rounded" required />
            <small class="text-red-500 hidden error-msg">Medical Expiry is required</small>
          </div>
  
          <div>
            <label class="text-sm text-gray-600">TWIC Card?</label>
            <div class="flex gap-4 mt-2">
              <label><input type="radio" name="TWIC"  value="Yes" /> Yes</label>
              <label><input type="radio" name="TWIC"  value="No" /> No</label>
            </div>
          </div>
  
          <div>
            <label class="text-sm text-gray-600">Passport?</label>
            <div class="flex gap-4 mt-2">
              <label><input type="radio" name="Passport"  value="Yes"/> Yes</label>
              <label><input type="radio" name="Passport"  value="No" /> No</label>
            </div>
          </div>
        </div>
  
        <!-- UPLOAD BOX -->
          <div class="mt-6">
            <label class="text-sm text-gray-600">Upload Medical Card <span class="text-red-600">*</span></label>
          
            <label
              class="mt-2 border-2 border-dashed rounded-lg p-6 text-center cursor-pointer hover:bg-gray-50 block"
            >
              <p class="text-gray-500 text-sm">Upload a file or drag and drop</p>
              <p class="text-xs text-gray-400">PNG, JPG, PDF up to 10MB</p>
          
              <!-- Hidden File Input -->
              <input
                type="file"
                
                name="medicalImage"
                accept=".png,.jpg,.jpeg,.pdf"
                onchange="handleFileUpload(event)"
                required
              />

            </label>
         
          </div>
     <small class="text-red-500 hidden error-msg">Medical Card is required</small>
        <!-- SOCIAL CARD -->
        <h2 class="text-lg font-semibold mt-8 border-b pb-2">
          Social Security Card
        </h2>
  
        <div class="mt-4">
          
          <label class="text-sm text-gray-600"
            >Upload Social Security Card <span class="text-red-600">*</span></label
          >
   
      
          <label
          class="mt-2 border-2 border-dashed rounded-lg p-6 text-center cursor-pointer hover:bg-gray-50 block"
        >
          <p class="text-gray-500 text-sm">Upload Social Security Card <span class="text-red-600">*</span></p>
          <p class="text-xs text-gray-400">PNG, JPG, PDF up to 10MB</p>
      
          <!-- Hidden File Input -->
          <input
            type="file"
            name="ssnImage"
  required
            
            accept=".png,.jpg,.jpeg,.pdf"
            onchange="handleFileUpload(event)"
          />
        </label>
       
        </div>
   <small class="text-red-500 hidden error-msg">Social Security Card is required</small>
        <!-- BUTTON -->
        <div class="flex justify-between items-center mt-8">
       
     <button
                type="button"
                class=" clear-form items-center px-3 py-2 text-red-500 text-[10px] sm:text-xs font-medium hover:bg-red-50 rounded-lg transition-colors border border-transparent hover:border-red-100"
                title="Clear all data"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="lucide lucide-refresh-cw w-3 h-3 mr-1.5"
                  aria-hidden="true"
                >
                  <path
                    d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"
                  ></path>
                  <path d="M21 3v5h-5"></path>
                  <path
                    d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"
                  ></path>
                  <path d="M8 16H3v5"></path></svg
                >Clear Form
              </button>
  
          <button class="next-btn bg-blue-600 text-white px-6 py-2 rounded-lg">
            Next Step →
          </button>
        </div>
      </div>
    </div>
  
    <script>
      function handleFileUpload(event) {
        const file = event.target.files[0];
        if (file) {
          console.log("Selected file:", file.name);
          alert("File selected: " + file.name);
        }
      }
    </script>
    

    <!-- -------------------------------------resdence------------------------ -->

    <div class="form-step hidden" data-step="1">
      <div class="mx-auto mt-3 bg-white shadow-lg rounded-xl p-6">
        <!-- HEADER -->
        <h2 class="text-lg font-semibold text-blue-600 border-b pb-2">
          Residence History
        </h2>
  
        <!-- GRID -->
        <div class="grid md:grid-cols-3 gap-4 mt-4">
          <div>
            <label class="text-sm text-gray-600">Address<span class="text-red-600"><span class="text-red-600">*</span></span></label>
            <input
              type="text"
              name="ResidenceAddress"
              placeholder="Address"
              class="w-full mt-1 p-2 border rounded focus:ring-2 focus:ring-blue-400"
              required
            />
           <small class="text-red-500 hidden error-msg">Address  is required</small>

          </div>
  
          <div>
            <label class="text-sm text-gray-600">City <span class="text-red-600">*</span></label>
            <input  name="ResidenceCity"
              type="text"
              placeholder="City"
              class="w-full mt-1 p-2 border rounded focus:ring-2 focus:ring-blue-400"
              required
            />
           <small class="text-red-500 hidden error-msg">City  is required</small>
          
          </div>
  
          <div>
            <label class="text-sm text-gray-600">State <span class="text-red-600">*</span></label>
            <input  name="ResidenceState"
              type="text"
              placeholder="State"
              class="w-full mt-1 p-2 border rounded focus:ring-2 focus:ring-blue-400"
              required
            />
           <small class="text-red-500 hidden error-msg">State  is required</small>
          
          </div>
  
          <div>
            <label class="text-sm text-gray-600"> Country <span class="text-red-600">*</span></label>
            <input  name="ResidenceCountry"
              type="text"
              placeholder="Country "
              class="w-full mt-1 p-2 border rounded" required
            />
           <small class="text-red-500 hidden error-msg">Country  is required</small>
          
          </div>
  
          <div>
            <label class="text-sm text-gray-600">Zip Code <span class="text-red-600">*</span> </label>
            <input  name="ResidenceZip"
              type="text"
              placeholder="Zip Code"
              class="w-full mt-1 p-2 border rounded" required
            />
           <small class="text-red-500 hidden error-msg">Zip Code  is required</small>
          
          </div>
        </div>
  
        <!-- MEDICAL SECTION -->
        <h2 class="text-lg font-semibold mt-8 border-b pb-2">
          Emergency Contact
        </h2>
  
        <div class="grid md:grid-cols-3 gap-4 mt-4">
          <div>
            <label class="text-sm text-gray-600">Full Name <span class="text-red-600">*</span></label>
            <input  name="EmergencyFullname" class="w-full mt-1 p-2 border rounded" required />
           <small class="text-red-500 hidden error-msg">Full Name  is required</small>
          
          </div>
  
          <div>
            <label class="text-sm text-gray-600">Relationship <span class="text-red-600">*</span></label>
            <input  name="EmRelationship" type="text" class="w-full mt-1 p-2 border rounded" required />
           <small class="text-red-500 hidden error-msg">Relationship  is required</small>
          
          </div>
  
          <div>
            <label class="text-sm text-gray-600">Phone Number <span class="text-red-600">*</span></label>
            <input  name="EmPhone" type="number" class="w-full mt-1 p-2 border rounded" required />
           <small class="text-red-500 hidden error-msg">Phone Number  is required</small>
          
          </div>
        </div>
  
        <!-- BUTTON -->
        <div class="flex justify-between items-center mt-8">
        <button
                type="button"
                class=" clear-form items-center px-3 py-2 text-red-500 text-[10px] sm:text-xs font-medium hover:bg-red-50 rounded-lg transition-colors border border-transparent hover:border-red-100"
                title="Clear all data"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="lucide lucide-refresh-cw w-3 h-3 mr-1.5"
                  aria-hidden="true"
                >
                  <path
                    d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"
                  ></path>
                  <path d="M21 3v5h-5"></path>
                  <path
                    d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"
                  ></path>
                  <path d="M8 16H3v5"></path></svg
                >Clear Form
              </button>
  
          <button class="next-btn bg-blue-600 text-white px-6 py-2 rounded-lg">
            Next Step →
          </button>
        </div>
      </div>
    </div>
    

    <!-- licencse -->


    <%- include('./licencse.ejs') %>

    <!-- drving ex -->

    <%- include('./drving.ejs') %>

    <!-- incident -->

 
    <%- include('./incident.ejs') %>

    <!-- employment -->

    <%- include('./employment.ejs') %>

    <!-- 7days -->
    <%- include('./7days.ejs') %>

  

    <!-- -------------------consent------------------------------- -->
    <div class="form-step hidden" data-step="7">

      <div
        class="bg-white rounded-2xl shadow-xl shadow-slate-200/50 border border-gray-100 overflow-hidden"
      >
        <div
          class="bg-gradient-to-r from-blue-600 to-blue-700 p-1 h-2 w-full"
        ></div>
        <div class="p-4 sm:p-6 md:p-10">
          <form novalidate="" class="min-h-[400px]">
            <div class="animate-fadeIn">
              <div class="mb-4 sm:mb-6 border-b pb-2">
                <h2 class="text-lg sm:text-xl font-bold text-gray-800">
                  Final Consents
                </h2>
                <p class="text-xs sm:text-sm text-gray-500 mt-0.5 sm:mt-1">
                  Please read carefully and accept all terms to proceed.
                </p>
              </div>
              <div
                class="mb-8 p-4 bg-blue-50 border-l-4 border-blue-500 rounded-r text-sm text-blue-900 leading-relaxed"
              >
                <p class="font-semibold mb-1">Legal Disclaimer:</p>
                By submitting this application, I certify that I have read and
                understood all the above documents and that the information
                provided is true and complete to the best of my knowledge.
              </div>
              <div class="space-y-4 mb-8">
                <div
                  class="flex items-center justify-between p-4 rounded-xl border transition-all bg-white border-gray-200 hover:border-blue-200 hover:shadow-sm"
                >
                  <label
                    class="flex items-center space-x-3 cursor-pointer flex-grow select-none"
                    >
                    <input  type="checkbox" data-key="Consents1" class="consent-checkbox" /><span
                      class="text-sm font-medium transition-colors text-gray-700"
                      >FMCSA Clearinghouse Limited Query Consent</span
                    ></label
                  ><button
                    type="button"
                    onclick="openModal(this)" data-consent="Consents1"
                    class="flex items-center ml-4 px-3 py-1.5 text-xs font-semibold text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors border border-blue-100"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="lucide lucide-eye w-3.5 h-3.5 mr-1.5"
                      aria-hidden="true"
                    >
                      <path
                        d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"
                      ></path>
                      <circle cx="12" cy="12" r="3"></circle></svg
                    >View
                  </button>
                </div>
                <div
                  class="flex items-center justify-between p-4 rounded-xl border transition-all bg-white border-gray-200 hover:border-blue-200 hover:shadow-sm"
                >
                  <label
                    class="flex items-center space-x-3 cursor-pointer flex-grow select-none"
                    >
                    <input  type="checkbox" data-key="Consents2" class="consent-checkbox" /><span
                      class="text-sm font-medium transition-colors text-gray-700"
                      >FMCSA PSP Disclosure &amp; Authorization</span
                    ></label
                  ><button
                    type="button"
                    onclick="openModal(this)" data-consent="Consents2"
                    class="flex items-center ml-4 px-3 py-1.5 text-xs font-semibold text-blue-600 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors border border-blue-100"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="lucide lucide-eye w-3.5 h-3.5 mr-1.5"
                      aria-hidden="true"
