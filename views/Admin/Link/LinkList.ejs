<script>
  function copyLink(btn, text) {
    navigator.clipboard.writeText(text).then(() => {
      
      const original = btn.innerHTML;
      btn.innerHTML = "✅";

      setTimeout(() => {
        btn.innerHTML = original;
      }, 1500);

    }).catch(() => {
      alert("Copy failed!");
    });
  }
</script>
