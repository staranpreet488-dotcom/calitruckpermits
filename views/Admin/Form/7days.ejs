          </div>
  
          <!-- DAYS CONTAINER (JS will fill this) -->
          <div class="mt-4 border rounded-xl overflow-hidden">
  
            <div class="bg-slate-800 text-white grid grid-cols-2 px-6 py-3 text-sm font-semibold">
              <span>Date</span>
              <span>Hours On Duty</span>
            </div>
  
            <div id="daysContainer" class="divide-y"></div>
  
            <!-- TOTAL -->
            <div class="bg-blue-50 grid grid-cols-2 px-6 py-4">
              <span class="font-bold text-blue-800">Total Hours (7 Days)</span>
              <input
                name="totalHours"
                id="totalHours"
                readonly
                class="bg-white border border-blue-200 rounded-lg px-3 py-2 max-w-[160px] font-bold text-blue-700"
                value="0"
              />
            </div>
  
          </div>
  
