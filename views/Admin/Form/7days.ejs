      <div class="p-4 sm:p-6 md:p-10">
  
        <form id="step6Form" class="min-h-[400px]">
  
          <!-- HEADER -->
          <div class="mb-6 border-b pb-2">
            <h2 class="text-lg font-bold text-gray-800">
