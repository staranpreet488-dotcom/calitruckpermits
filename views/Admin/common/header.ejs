  <% if(msg !='' ) { %>
  <div class="alert alert-success msg" style="position: absolute; z-index: 9999; right: 170px; top: 38px;">
    <span style="font-size: 18px; padding: 10px; border-radius: 5px; color: rgb(232, 232, 240);  background-color: #1e4f99;">
      <%= msg %>
    </span>
  </div>
  <% } %>

