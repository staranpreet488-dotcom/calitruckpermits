<style>
.download-btn {
  background: linear-gradient(135deg, #2563eb, #1e40af);
  color: white;
  padding: 12px 28px;
  border: none;
  border-radius: 10px;
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
}

.download-btn:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 25px rgba(37, 99, 235, 0.5);
  background: linear-gradient(135deg, #1e40af, #1e3a8a);
}

.download-btn:active {
  transform: scale(0.98);
}
  /* ===== PREMIUM MODAL UPGRADE ===== */
/* Premium file box */
.file-box {
  border: 2px dashed #cbd5e1;
  padding: 25px;
  border-radius: 15px;
  background: #f8fafc;
  cursor: pointer;
  transition: 0.3s ease;
  text-align: center;
}

.file-box i {
  font-size: 28px;
  color: #2563eb;
  display: block;
  margin-bottom: 8px;
}

.file-box span {
  font-weight: 500;
  display: block;
}

.file-box small {
  display: block;
  margin-top: 8px;
  color: #16a34a;
  font-size: 13px;
}

.file-box:hover {
  border-color: #2563eb;
  background: #eff6ff;
  transform: scale(1.02);
}

/* Active state after select */
.file-box.active {
  border-color: #16a34a;
  background: #ecfdf5;
}
.modal {
  backdrop-filter: blur(8px);
  background: rgba(15, 23, 42, 0.65);
  display: none;
  align-items: center;
  justify-content: center;
  animation: fadeIn 0.3s ease;
}

.modal-content {
  background: linear-gradient(145deg, #ffffff, #f8fafc);
  padding: 30px;
  width: 420px;
  border-radius: 18px;
  box-shadow: 0 25px 60px rgba(0,0,0,0.25);
  text-align: center;
  position: relative;
  animation: slideUp 0.35s ease;
}

/* Close button premium */
.modal-content .close {
  position: absolute;
  right: 18px;
  top: 15px;
  font-size: 20px;
  cursor: pointer;
  color: #64748b;
  transition: 0.3s;
}

.modal-content .close:hover {
  color: #ef4444;
  transform: rotate(90deg);
}

/* File input box style */
#fileInput {
  width: 100%;
  padding: 12px;
  border: 2px dashed #cbd5e1;
  border-radius: 12px;
  background: #f8fafc;
  cursor: pointer;
  transition: 0.3s;
  margin-top: 15px;
}

#fileInput:hover {
  border-color: #2563eb;
  background: #eff6ff;
}

/* Upload button premium */
.modal-content button {
  width: 100%;
  margin-top: 20px;
  padding: 12px;
  border: none;
  border-radius: 12px;
  background: linear-gradient(135deg, #2563eb, #1e40af);
  color: white;
  font-weight: 500;
  cursor: pointer;
  transition: 0.3s;
}

.modal-content button:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(37, 99, 235, 0.4);
}

/* Smooth Animations */
@keyframes fadeIn {
  from { opacity: 0 }
  to { opacity: 1 }
}

@keyframes slideUp {
  from { transform: translateY(30px); opacity: 0 }
  to { transform: translateY(0); opacity: 1 }
}
.modal-content {
  border: 1px solid rgba(255,255,255,0.3);
}
