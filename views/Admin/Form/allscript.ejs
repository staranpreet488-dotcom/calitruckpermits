<script>
    const canvas = document.querySelector("canvas");
    const ctx = canvas.getContext("2d");
  
    let drawing = false;
  
    // Mouse Events
    canvas.addEventListener("mousedown", () => {
      drawing = true;
    });
  
    canvas.addEventListener("mouseup", () => {
      drawing = false;
      ctx.beginPath();
    });
  
    canvas.addEventListener("mousemove", draw);
  
    function draw(e) {
      if (!drawing) return;
  
      ctx.lineWidth = 2;
      ctx.lineCap = "round";
      ctx.strokeStyle = "#000";
  
      const rect = canvas.getBoundingClientRect();
      ctx.lineTo(e.clientX - rect.left, e.clientY - rect.top);
      ctx.stroke();
      ctx.beginPath();
      ctx.moveTo(e.clientX - rect.left, e.clientY - rect.top);
    }
  
    // Touch Support (Mobile)
    canvas.addEventListener("touchstart", (e) => {
      drawing = true;
    });
  
    canvas.addEventListener("touchend", () => {
      drawing = false;
      ctx.beginPath();
    });
  
    canvas.addEventListener("touchmove", (e) => {
      e.preventDefault();
      const rect = canvas.getBoundingClientRect();
      const touch = e.touches[0];
  
      ctx.lineWidth = 2;
      ctx.lineCap = "round";
      ctx.strokeStyle = "#000";
  
      ctx.lineTo(touch.clientX - rect.left, touch.clientY - rect.top);
      ctx.stroke();
      ctx.beginPath();
      ctx.moveTo(touch.clientX - rect.left, touch.clientY - rect.top);
    });
  
    // Clear Button
    const clearBtn = document.querySelector(".clear-signature-btn");

    clearBtn.disabled = false;
  
    clearBtn.addEventListener("click", () => {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.beginPath(); // 🔥 important reset
    });
 
  </script>
    <script>
      // Accident

      document.querySelectorAll(".exp-accident").forEach((box) => {
        const check = box.querySelector(".acc-check");
        const fields = box.querySelector(".acc-fields");

        check.addEventListener("change", () => {
          fields.classList.toggle("hidden", check.checked);
        });

        // default
        fields.classList.toggle("hidden", check.checked);
      });

      // Violation
      document.querySelectorAll(".exp-violation").forEach((box) => {
        const check = box.querySelector(".vio-check");
        const fields = box.querySelector(".vio-fields");

        check.addEventListener("change", () => {
          fields.classList.toggle("hidden", check.checked);
        });

        // default
        fields.classList.toggle("hidden", check.checked);
      });



     
    </script>

    <script>
      document.querySelectorAll(".exp-row").forEach((row) => {
        const radios = row.querySelectorAll('input[type="radio"]');
        const fields = row.querySelectorAll(".exp-fields");

        radios.forEach((radio) => {
          radio.addEventListener("change", () => {
            if (radio.value === "yes") {
              fields.forEach((f) => f.classList.remove("hidden"));
            } else {
              fields.forEach((f) => f.classList.add("hidden"));
            }
          });
        });

        // default load
        const checked = row.querySelector("input:checked");
        if (checked) checked.dispatchEvent(new Event("change"));
      });
    </script>


