<%
const consentTitles = [
  "FMCSA Clearinghouse Limited Query Consent",
  "FMCSA PSP Disclosure & Authorization",
  "Pre-Employment Employee Alcohol & Drug Test Statement",
  "Safety Performance History Investigationt",
  "Employer Pull Notice Program Authorization (CA EPN)",
  "Motor Vehicle Record (MVR) Consent",
  "General Work Policy & Driver Handbook Acknowledgment",
  "Drug & Alcohol Policy Acknowledgment"
];

const totalConsents = 8;
const uploadedConsents = viewpdf.Consents || [];
const uploadedCount = uploadedConsents.length;
const isCompleted = uploadedCount === totalConsents;
%>
<div class="doc-card">

  <div class="doc-header">
    <div class="left">
      <h4 class="h4">Driver Consents</h4>
     


      <span class="status <%= isCompleted ? 'completed' : 'incomplete' %>">
        <%= isCompleted ? 'COMPLETED' : 'INCOMPLETE' %>
      </span>

      <span class="consent-badge">
        <%= uploadedCount %> / <%= totalConsents %>
      </span>
    </div>
  </div>

  <label class="view-doc" onclick="toggleConsents()">
   👁 View All Consents
  </label>

  <div id="consentDropdown" class="dropdown">

    <% consentTitles.forEach(function(title, index) { %>

