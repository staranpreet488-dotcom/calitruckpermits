<div class="form-step hidden" data-step="2">
    <div class="mx-auto mt-3 bg-white shadow-lg rounded-xl p-6">
      <!-- HEADER -->
      <h2 class="text-lg font-semibold text-blue-600 border-b pb-2">
        License Details
      </h2>

      <!-- GRID -->
      <div class="grid md:grid-cols-3 gap-4 mt-4">
        <div>
          <label class="text-sm text-gray-600">First Name <span class="text-red-600">*</span></label>
          <input name="LicenseFullName"
            type="text"
            name="LicenseFullName"
            placeholder="First Name"
            class="w-full mt-1 p-2 border rounded focus:ring-2 focus:ring-blue-400"
            required
          />
           <small class="text-red-500 hidden error-msg">First Name  is required</small>
        
        </div>

        <div>
          <label class="text-sm text-gray-600">Last Name <span class="text-red-600">*</span></label>
          <input name="LicenseLastName"
            type="text"
            placeholder="Last Name"
            class="w-full mt-1 p-2 border rounded focus:ring-2 focus:ring-blue-400"
            required
          />
           <small class="text-red-500 hidden error-msg">Last Name  is required</small>
        
        </div>

        <div>
          <label class="text-sm text-gray-600">License Number <span class="text-red-600">*</span></label>
          <input name="LicenseNumber"
            type="text"
            placeholder="xxx-xx-xxxx"
            class="w-full mt-1 p-2 border rounded focus:ring-2 focus:ring-blue-400"
            required
          />
           <small class="text-red-500 hidden error-msg">License Number  is required</small>
        
        </div>

        <div>
          <label class="text-sm text-gray-600"
            >Re-enter License Number <span class="text-red-600">*</span></label
          >
          <input name="ReenterLicenseNumber"
            type="text"
            placeholder="10-15 r"
            class="w-full mt-1 p-2 border rounded"
            required
          />
           <small class="text-red-500 hidden error-msg"> Please Re-enter License Number</small>
        
        </div>

        <div>
          <label class="text-sm text-gray-600">Country <span class="text-red-600">*</span></label>
          <input name="LicenseCountry"
            type="text"
            placeholder="Country"
            class="w-full mt-1 p-2 border rounded"
            required
          />
           <small class="text-red-500 hidden error-msg">Country  is required</small>
        
        </div>

        <div>
          <label class="text-sm text-gray-600">State <span class="text-red-600">*</span></label>
          <input name="LicenseState" type="text" class="w-full mt-1 p-2 border rounded"
          required />
           <small class="text-red-500 hidden error-msg">State  is required</small>
        
        </div>

        <div class="md:col-span-2">
          <label class="text-sm text-gray-600">Class <span class="text-red-600">*</span></label>
          <input name="LicenseClass"
            type="email"
            placeholder="email@example.com"
            class="w-full mt-1 p-2 border rounded"
            required
          />
           <small class="text-red-500 hidden error-msg">Class  is required</small>
        
        </div>

        <div class="md:col-span-3">
          <label class="text-sm text-gray-600">Issue Date <span class="text-red-600">*</span></label>
          <input name="LicenseIssueDate"
            type="date"
            placeholder="Issue Date"
            class="w-full mt-1 p-2 border rounded"
            required
          />
           <small class="text-red-500 hidden error-msg">Issue Date is required</small>
        
        </div>

        <div>
          <label class="text-sm text-gray-600">Expiry Date <span class="text-red-600">*</span></label>
          <input name="LicenseExpiryDate" type="date" class="w-full mt-1 p-2 border rounded"
          required />
           <small class="text-red-500 hidden error-msg">Expiry Date  is required</small>
        
        </div>
      </div>

      <!-- MEDICAL SECTION -->
      <h2 class="text-lg font-semibold mt-8 border-b pb-2">License Images</h2>
      <h4>Please upload clear images of your license</h4>

      <!-- UPLOAD BOX -->
      <div class="mt-6">
        <label class="text-sm text-gray-600">License Front <span class="text-red-600">*</span></label>

        <div
          class="mt-2 border-2 border-dashed rounded-lg p-6 text-center cursor-pointer hover:bg-gray-50"
        >
          <p class="text-gray-500 text-sm">Upload a file or drag and drop</p>
          <p class="text-xs text-gray-400">PNG, JPG, PDF up to 10MB</p>
          <input
          type="file"
          name="image"
required
          
          accept=".png,.jpg,.jpeg,.pdf"
          onchange="handleFileUpload(event)"
        />
      </label>
           <small class="text-red-500 hidden error-msg">License Front  is required</small>

        </div>
      </div>
      <div class="mt-6">
        <label class="text-sm text-gray-600">License Back <span class="text-red-600">*</span></label>

        <div
          class="mt-2 border-2 border-dashed rounded-lg p-6 text-center cursor-pointer hover:bg-gray-50"
        >
          <p class="text-gray-500 text-sm">Upload a file or drag and drop</p>
          <p class="text-xs text-gray-400">PNG, JPG, PDF up to 10MB</p>
          <input
          type="file"
          name="image1"
required
          
          accept=".png,.jpg,.jpeg,.pdf"
          onchange="handleFileUpload(event)"
        />
      </label>
        </div>
           <small class="text-red-500 hidden error-msg">License Back  is required</small>

      </div>

      <!-- BUTTON -->
      <div class="flex justify-between items-center mt-8">
          <button
                type="button"
                class=" clear-form items-center px-3 py-2 text-red-500 text-[10px] sm:text-xs font-medium hover:bg-red-50 rounded-lg transition-colors border border-transparent hover:border-red-100"
                title="Clear all data"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="lucide lucide-refresh-cw w-3 h-3 mr-1.5"
                  aria-hidden="true"
                >
                  <path
                    d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"
                  ></path>
                  <path d="M21 3v5h-5"></path>
                  <path
                    d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"
                  ></path>
                  <path d="M8 16H3v5"></path></svg
                >Clear Form
              </button>
  

        <button class="next-btn bg-blue-600 text-white px-6 py-2 rounded-lg">
          Next Step →
        </button>
      </div>
    </div>
  </div>
  <script>
    function handleFileUpload(event) {
      const file = event.target.files[0];
      if (file) {
        console.log("Selected file:", file.name);
        alert("File selected: " + file.name);
      }
    }
  </script>
  