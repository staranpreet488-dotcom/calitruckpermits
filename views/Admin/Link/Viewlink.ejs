<style>
.img_small {
  width: 150px;   /* adjust kar sakda */
  height: 150px;
  object-fit: cover;
  border-radius: 8px;
}

.company-logo {
  width: 70px;
  height: 70px;
  background: #f1f1f1;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.company-logo i {
  width: 30px;
  height: 30px;
}

.stat-box {
  width: 120px;
  padding: 15px;
  border-radius: 12px;
  background: linear-gradient(145deg, #e6edf5, #ffffff);
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.stat-box i {
  width: 20px;
  height: 20px;
  margin-bottom: 5px;
}

.stat-box h3 {
  margin: 5px 0;
}
/* Company Name */
.company-title {
  font-weight: 600;
  font-size: 20px;
  color: #1f2937;
  letter-spacing: 0.3px;
}

/* Sub text (address, phone, email) */
.company-subtext {
  font-size: 13px;
  color: #6b7280;
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: 2px;
}

/* ACTIVE badge - premium look */
.status-badge {
  font-size: 11px;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: 999px;
  letter-spacing: 0.5px;
}

/* ACTIVE color like screenshot */
.status-badge1.active {
  background-color: #e6f4ea;
  color: #16a34a;
}
.status-badge1 {
  padding: 5px 10px;
  border-radius: 20px;
  color: #fff;
  font-size: 12px;
  text-transform: capitalize;
}
</style>

