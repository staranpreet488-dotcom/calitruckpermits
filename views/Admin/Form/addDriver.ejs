const nextBtns = document.querySelectorAll(".next-btn");
const stepLabels = document.querySelectorAll("#steps .step");
const stepIcons = document.querySelectorAll("[data-step]");

/* =========================
   VALIDATION FUNCTION
========================= */
function validateStep(step) {
  let isValid = true;

  const currentForm = document.querySelector(`.form-step[data-step="${step}"]`);

  // ONLY required fields
const inputs = currentForm.querySelectorAll("input[required]");

  inputs.forEach(input => {
    const parent = input.parentElement;
    const errorMsg = parent.querySelector(".error-msg");

    // radio skip (handle separately if needed)
    if (input.type === "radio") return;

    if (!input.value.trim()) {
      isValid = false;
      input.classList.add("error-border");

      if (errorMsg) errorMsg.classList.remove("hidden");
    }
  });

  return isValid;
}

/* =========================
   STEP UPDATE FUNCTION
========================= */
function updateStep(step) {
  currentStep = step;

  localStorage.setItem("formStep", currentStep);

  forms.forEach((form, i) => {
    form.classList.toggle("hidden", i !== step);
  });

  stepLabels.forEach((el) => {
    el.classList.remove("text-blue-600", "font-semibold");
  });

  const activeLabel = document.querySelector(`#steps .step[data-step="${step}"]`);
  if (activeLabel) {
    activeLabel.classList.add("text-blue-600", "font-semibold");
  }

  stepIcons.forEach((el) => {
    const circle = el.querySelector(".circle");
    if (!circle) return;

    circle.classList.remove("bg-blue-500", "text-white");
    circle.classList.add("border", "text-gray-500");

    if (parseInt(el.dataset.step) === step) {
      circle.classList.remove("border", "text-gray-500");
      circle.classList.add("bg-blue-500", "text-white");
    }
  });
}

/* =========================
   RESTORE STEP ON LOAD
========================= */
window.addEventListener("load", () => {
  const savedStep = localStorage.getItem("formStep");
  currentStep = savedStep ? parseInt(savedStep) : 0;
  updateStep(currentStep);
});

/* =========================
   NEXT BUTTON (FIXED)
========================= */
nextBtns.forEach((btn) => {
  btn.addEventListener("click", (e) => {
    e.preventDefault();

    // 🔥 VALIDATION CHECK FIRST
    if (!validateStep(currentStep)) return;

    // SAVE DATA
    if (currentStep === 0) saveStep0();
    if (currentStep === 1) saveStep1();
    if (currentStep === 2) saveStep2();
    if (currentStep === 3) saveStep3();
    if (currentStep === 4) saveStep4();
    if (currentStep === 5) saveStep5();
    if (currentStep === 6) saveStep6();

    console.log("Saved Data:", formData);

    // NEXT STEP
    if (currentStep < forms.length - 1) {
      updateStep(currentStep + 1);
    }
  });
});

/* =========================
   STEP NAV CLICK
========================= */
stepLabels.forEach((step) => {
  step.addEventListener("click", () => {
    const stepIndex = parseInt(step.dataset.step);
    updateStep(stepIndex);
  });
});

/* =========================
   REMOVE ERROR ON FOCUS
========================= */
document.querySelectorAll("input").forEach(input => {
  input.addEventListener("focus", function () {
    this.classList.remove("error-border");

    const errorMsg = this.parentElement.querySelector(".error-msg");
    if (errorMsg) errorMsg.classList.add("hidden");
  });
});
