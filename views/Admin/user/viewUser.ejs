<!-- Upload Modal -->
<div id="uploadModal" class="modal">
  <div class="modal-content">
    <span class="close" onclick="closeModal()">&times;</span>

    <h3 class="modal-title">Upload Document</h3>
    <p class="modal-sub">PDF, JPG, PNG (Max 10MB)</p>

    <label class="file-drop">
      <input type="file" id="fileInput" hidden onchange="showSelectedFile(this)">
      
      <div class="file-box" id="fileBox">
        <i class="bi bi-cloud-arrow-up"></i>
        <span id="fileText">Select File</span>
        <small id="fileNamePreview"></small>
      </div>
    </label>

    <button class="upload-btn" onclick="uploadFile()">Start Upload</button>
  </div>
</div>

<!-- viewmodal -->

<!-- View Modal -->
<div id="viewModal" class="modal">
  <div class="modal-content" style="width: 70%;">
    <span onclick="closeViewModal()" style="float:right;cursor:pointer">&times;</span>

    <div id="documentContainer" style="height:500px;"></div>
  </div>
</div>
<div class="sidenav-overlay"></div>
<div class="drag-target"></div>
<script>
function showSelectedFile(input) {
  const preview = document.getElementById("fileNamePreview");
  const box = document.getElementById("fileBox");

  if (input.files.length > 0) {
    const file = input.files[0];

    // File size validation (10MB)
    if (file.size > 10 * 1024 * 1024) {
      alert("File must be less than 10MB");
      input.value = "";
      return;
    }

    preview.innerHTML = "✅ " + file.name;
    box.classList.add("active");
  }
}
</script>

<script>
function openViewModal(filePath) {

  if (!filePath) {
    alert("No document uploaded");
    return;
  }

  const BASE_URL =
    window.location.hostname === "localhost"
      ? "http://localhost:2000"
      : "http://portal.calipermits.com";

  const fileUrl = filePath.startsWith("http")
    ? filePath
    : BASE_URL + filePath;
console.log(fileUrl,"fileUrlfileUrlfileUrl")
  const container = document.getElementById("documentContainer");

  if (fileUrl.toLowerCase().includes(".pdf")) {
    container.innerHTML = `
      <iframe src="${fileUrl}" width="100%" height="100%"></iframe>
    `;
  } else {
    container.innerHTML = `
      <img src="${fileUrl}" style="max-width:100%; max-height:100%;" />
    `;
  }

  document.getElementById("viewModal").style.display = "flex";
}
  
  function closeViewModal() {
    document.getElementById("viewModal").style.display = "none";
  }
  </script>

<script>
  let selectedType = "";
  
  function openModal(type) {
    selectedType = type; // RoadTest / MVRRecord / ClearingHouse
    document.getElementById("uploadModal").style.display = "flex";
  }
  
  function closeModal() {
    document.getElementById("uploadModal").style.display = "none";
  }
  
  async function uploadFile() {
    const fileInput = document.getElementById("fileInput");
    const file = fileInput.files[0];
  
    if (!file) {
      alert("Please select a file");
      return;
    }
  
    const formData = new FormData();
    formData.append(selectedType, file);
  
    const urlParts = window.location.pathname.split("/");
    const driverId = urlParts[urlParts.length - 1];
  
    try {
      const response = await fetch(`/companydocument/${driverId}`, {
        method: "POST",
        body: formData
      });
  
      const result = await response.json();
  
      if (result.success) {
        alert("File Uploaded Successfully");
        closeModal();
        location.reload();
      }
  
    } catch (error) {
      console.log(error);
    }
  }
  </script>
<script>
  function copyLink(id) {
    const input = document.getElementById("dqLink_" + id);
    input.select();
    input.setSelectionRange(0, 99999);

    navigator.clipboard.writeText(input.value)
      .then(() => {
        alert("Link copied ✅");
        location.reload(); 
      })
      .catch(() => {
        alert("Copy failed ❌");
      });
  }
</script>
<script>
  const tabs = document.querySelectorAll('.nav-pill');
  const contents = document.querySelectorAll('.tab-content');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {

      // remove active from all
      tabs.forEach(t => t.classList.remove('active'));
      contents.forEach(c => c.classList.remove('active'));

      // add active to clicked
      tab.classList.add('active');

      // show related content
      const target = tab.getAttribute('data-tab');
      document.getElementById(target).classList.add('active');
    });
  });
</script>



